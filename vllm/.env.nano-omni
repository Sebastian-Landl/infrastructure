# =============================================================================
# Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4 — multimodal (video/audio/image/text)
# Usage: docker compose --env-file .env.nano-omni up -d
#
# Required: vLLM v0.20.0-cu130 (already pinned in docker-compose.yml).
#
# Pre-flight:
#   - Model is ~21 GB (NVFP4). Ensure HF_CACHE_DIR has ≥25 GB free.
#   - Model card: https://huggingface.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
#   - No external reasoning parser file needed — nemotron_v3 is built into vLLM 0.20.0.
#
# Audio support:
#   Set VLLM_INSTALL_AUDIO_DEPS=1 to have the container install vllm[audio] before serving.
#   Only needed if you will pass audio inputs to the model.
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- SM12.1 kernel routing ---
VLLM_NVFP4_GEMM_BACKEND=marlin
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_FLASHINFER_MOE_BACKEND=latency
VLLM_FLASHINFER_ALLREDUCE_BACKEND=

# --- Context / memory ---
VLLM_ALLOW_LONG_MAX_MODEL_LEN=0
VLLM_MAX_MODEL_LEN=131072
VLLM_MAX_NUM_SEQS=8
VLLM_GPU_MEMORY_UTILIZATION=0.85

# --- Quantization ---
# NVFP4 quant_algo is auto-detected from the checkpoint — no explicit flag needed.
VLLM_QUANTIZATION_FLAG=

# --- MoE / Mamba ---
VLLM_MOE_BACKEND=marlin
MAMBA_SSM_CACHE_DTYPE=float32

# --- Scheduling ---
VLLM_ASYNC_SCHEDULING_FLAG=

# --- CUDA graph ---
VLLM_CUDAGRAPH_FLAG=

# --- Speculative decoding ---
VLLM_SPECULATIVE_CONFIG_FLAG=

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8

# --- Multimodal flags ---
# Video pruning reduces VRAM by dropping redundant visual tokens.
VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 is recommended for 80 GB GPUs; reduce to 64-128 for ≤40 GB.
VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
# Allows the server to load local file:// URIs (needed for local video/audio paths).
VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /
# Optional: cap multimodal inputs per request (uncomment to enable).
# VLLM_LIMIT_MM_FLAG=--limit-mm-per-prompt '{"video": 1, "image": 1, "audio": 1}'
VLLM_LIMIT_MM_FLAG=

# --- Audio dependency ---
# Set to 1 if you will use audio inputs (adds ~30 s to container startup).
VLLM_INSTALL_AUDIO_DEPS=0

# --- Reasoning parser ---
# nemotron_v3 is built into vLLM 0.20.0 — no plugin file required.
VLLM_REASONING_PARSER_PLUGIN=
VLLM_REASONING_PARSER=nemotron_v3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
VLLM_PORT=8000
