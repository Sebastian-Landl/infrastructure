# =============================================================================
# nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4 — multimodal (video/audio/image/text)
# Usage: docker compose --env-file .env.nano-omni up -d
#
# Model card: https://huggingface.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
# Max supported context: 131072 tokens.
#
# Audio support:
#   Set VLLM_INSTALL_AUDIO_DEPS=1 to have the container install vllm[audio] before serving.
#   Only needed if you will pass audio inputs to the model.
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- Reasoning / tool calling ---
# nemotron_v3 is built into vLLM 0.20.x — no plugin file required.
VLLM_REASONING_PARSER_PLUGIN=
VLLM_REASONING_PARSER=nemotron_v3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- Attention / MoE backend ---
VLLM_ATTENTION_BACKEND=flashinfer
# flashinfer_cutlass is recommended for NVFP4 MoE models.
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_QUANTIZATION=compressed-tensors
VLLM_NVFP4_GEMM_BACKEND=marlin

# --- Speculative decoding ---
# Nano Omni does not support speculative decoding.
VLLM_SPECULATIVE_CONFIG_FLAG=

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=16
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.75

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8_e4m3
# bfloat16 is correct for NVFP4 on Ampere+; float16 is narrower dynamic range
VLLM_DTYPE=bfloat16

# --- Multimodal flags (video + audio + image) ---
VLLM_INSTALL_AUDIO_DEPS=1
VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 for 80 GB GPUs; reduce to 64-128 for ≤40 GB
VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
