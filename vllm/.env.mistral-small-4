# =============================================================================
# mistralai/Mistral-Small-4-119B-2603-NVFP4 — text / reasoning / tool-calling
# Usage: docker compose --env-file .env.qwen3.6 up -d
#
# Note: Model card says "compatible and tested against vllm main".
#       Use vllm/vllm-openai:v0.20.2 (latest stable; no cu130 variant exists).
#
# Model card: https://huggingface.co/mistralai/Mistral-Small-4-119B-2603-NVFP4
# Max supported context: 262144 tokens.
# =============================================================================

# --- Model ---
VLLM_MODEL=mistralai/Mistral-Small-4-119B-2603-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm
VLLM_IMAGE=vllm/vllm-openai:v0.21.0

# --- Reasoning / tool calling ---
VLLM_REASONING_PARSER=mistral
VLLM_TOOL_CALL_PARSER=mistral

# --- Attention / MoE backend ---
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_QUANTIZATION=compressed-tensors

# --- Speculative decoding (MTP) ---
#VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method":"eagle","model":"mistralai/Mistral-Small-4-119B-2603-eagle","num_speculative_tokens":10,"max_model_len":"65536"}'
#VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method": "mtp", "num_speculative_tokens": 3}'
#VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method": "ngram","num_speculative_tokens": 5}'

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=16
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.75

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8_e4m3
# bfloat16 is correct for NVFP4 on Ampere+; float16 is narrower dynamic range
VLLM_DTYPE=bfloat16

# --- Multimodal flags (image + video; no audio) ---
VLLM_INSTALL_AUDIO_DEPS=0
#VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 for 80 GB GPUs; reduce to 64-128 for ≤40 GB
#VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
#VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
