CONTAINER_NAME=vllm
HF_CACHE_DIR=~/.cache/huggingface
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
VLLM_SERVED_MODEL_NAME=nemotron-3-super
VLLM_REASONING_PARSER_PLUGIN=/app/reasoning_parsers/super_v3_reasoning_parser.py
VLLM_REASONING_PARSER=super_v3
# 1 for models lengths of 1M and more, 0 otherwise
VLLM_ALLOW_LONG_MAX_MODEL_LEN=0
VLLM_MAX_MODEL_LEN=262144
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_KV_CACHE_DTYPE=fp8
# bfloat16 is correct for NVFP4 on Ampere+; float16 is narrower dynamic range
VLLM_DTYPE=bfloat16
VLLM_TOOL_CALL_PARSER=qwen3_coder
# float16 or float32
MAMBA_SSM_CACHE_DTYPE=float16
VLLM_SPECULATIVE_CONFIG_FLAG=--speculative_config '{"method":"mtp","num_speculative_tokens":3,"moe_backend":"triton"}'
# Number of parallel forward passes; 4 to avoid OOM, for small context workloads 8-16 (or higher, depending on available GPU memory) can be used
VLLM_MAX_NUM_SEQS=4