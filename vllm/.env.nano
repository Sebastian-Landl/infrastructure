# =============================================================================
# Nemotron-3-Nano-30B-A3B-NVFP4 — DGX Spark (GB10 / SM12.1)
# Usage: docker compose --env-file .env.nano up -d
#
# Pre-flight:
#   mkdir -p reasoning_parsers
#   wget https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4/resolve/main/nano_v3_reasoning_parser.py \
#        -P ./reasoning_parsers/
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
VLLM_SERVED_MODEL_NAME=nemotron-3-nano
CONTAINER_NAME=vllm-nemotron-3-nano

# --- SM12.1 kernel routing ---
# Nano uses the FlashInfer FP4 MoE path; Marlin backend still applies
# for the GEMM kernels themselves (same path as Super)
VLLM_NVFP4_GEMM_BACKEND=marlin
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_FLASHINFER_MOE_BACKEND=latency
# Not needed for Nano (single GPU, no NCCL all-reduce)
VLLM_FLASHINFER_ALLREDUCE_BACKEND=

# --- Context / memory ---
VLLM_ALLOW_LONG_MAX_MODEL_LEN=0
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=8
VLLM_GPU_MEMORY_UTILIZATION=0.85

# --- Quantization ---
# Nano: quant_algo is auto-detected from checkpoint hf_quant_config.json
# as ModelOpt NVFP4 — no explicit --quantization flag required or accepted.
# Passing --quantization here causes a validation error on nightly.
VLLM_QUANTIZATION_FLAG=

# --- MoE / Mamba ---
VLLM_MOE_BACKEND=marlin
MAMBA_SSM_CACHE_DTYPE=float32

# --- Scheduling ---
# Nano does not use async scheduling
VLLM_ASYNC_SCHEDULING_FLAG=

# --- CUDA graph ---
# Nano does not need --max-cudagraph-capture-size; leave empty
VLLM_CUDAGRAPH_FLAG=

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8

# --- Parsers ---
VLLM_REASONING_PARSER_PLUGIN=/app/reasoning_parsers/nano_v3_reasoning_parser.py
VLLM_REASONING_PARSER=nano_v3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
VLLM_PORT=8000
