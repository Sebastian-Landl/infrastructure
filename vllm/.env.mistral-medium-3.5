# =============================================================================
# zdy1995love/Mistral-Medium-3.5-128B-NVFP4 — text / reasoning / tool-calling
# Usage: docker compose --env-file .env.mistral-medium-3.5 up -d
#
# Model card: https://huggingface.co/zdy1995love/Mistral-Medium-3.5-128B-NVFP4
# Based on: https://huggingface.co/mistralai/Mistral-Medium-3.5-128B
# Max supported context: ~98,304 tokens on a single 96 GiB GPU; larger memory or
# kv-offloading can push this higher.
# =============================================================================

# --- Model ---
VLLM_MODEL=zdy1995love/Mistral-Medium-3.5-128B-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- Reasoning / tool calling ---
VLLM_REASONING_PARSER=mistral
VLLM_TOOL_CALL_PARSER=mistral

# --- Attention / MoE backend ---
VLLM_ATTENTION_BACKEND=flashinfer
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_QUANTIZATION=compressed-tensors
VLLM_NVFP4_GEMM_BACKEND=marlin
VLLM_TOKENIZER_MODE=mistral

# --- Speculative decoding (EAGLE) ---
VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method":"eagle","model":"mistralai/Mistral-Medium-3.5-128B-EAGLE","num_speculative_tokens":3,"max_model_len":"65536"}'

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=98304
VLLM_MAX_NUM_SEQS=4
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.75

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8_e4m3
VLLM_DTYPE=bfloat16

# --- Multimodal flags (image + video; no audio) ---
VLLM_INSTALL_AUDIO_DEPS=0
#VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
#VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
#VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
