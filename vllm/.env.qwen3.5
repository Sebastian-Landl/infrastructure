# =============================================================================
# RedHatAI/Qwen3.5-122B-A10B-NVFP4 — text / reasoning / tool-calling
# Usage: docker compose --env-file .env.qwen3.5 up -d
#
# Model card: https://huggingface.co/RedHatAI/Qwen3.5-122B-A10B-NVFP4
# Max supported context: 131072 tokens.
# =============================================================================

# --- Model ---
VLLM_MODEL=RedHatAI/Qwen3.5-122B-A10B-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- Reasoning / tool calling ---
VLLM_REASONING_PARSER=qwen3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- Attention / MoE backend ---
# flashinfer_cutlass is recommended by the model card for this NVFP4 MoE model.
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_USE_FLASHINFER_MOE_FP4=1

# --- Speculative decoding (MTP) ---
# Qwen3.5 uses qwen3_next_mtp (different from Qwen3.6's generic mtp method).
VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method": "qwen3_next_mtp", "num_speculative_tokens": 2}'

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.8

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8
# bfloat16 is correct for NVFP4 on Ampere+; float16 is narrower dynamic range
VLLM_DTYPE=bfloat16

# --- Multimodal flags (image + video; no audio) ---
VLLM_INSTALL_AUDIO_DEPS=0
#VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 for 80 GB GPUs; reduce to 64-128 for ≤40 GB
#VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
#VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
VLLM_PORT=8000
