# =============================================================================
# nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4 — text / reasoning / tool-calling
# Usage: docker compose --env-file .env.super up -d
#
# Pre-flight:
#   mkdir -p reasoning_parsers
#   wget https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4/raw/main/super_v3_reasoning_parser.py \
#        -P ./reasoning_parsers/
#
# Model card: https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
# Max supported context: 262144 tokens (set VLLM_ALLOW_LONG_MAX_MODEL_LEN=1 for up to 1M).
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- Reasoning / tool calling ---
VLLM_REASONING_PARSER_PLUGIN=/app/reasoning_parsers/super_v3_reasoning_parser.py
VLLM_REASONING_PARSER=super_v3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- Attention / MoE backend ---
# flashinfer_cutlass is recommended for NVFP4 MoE models.
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_QUANTIZATION=compressed-tensors
VLLM_NVFP4_GEMM_BACKEND=marlin

# --- Speculative decoding (MTP) ---
# Super uses Multi-Token Prediction with 3 speculative tokens.
VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method": "mtp", "num_speculative_tokens": 3}'

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=4
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.75

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8_e4m3
# bfloat16 is correct for NVFP4 on Ampere+; float16 is narrower dynamic range
VLLM_DTYPE=bfloat16

# --- Multimodal flags (image + video; no audio) ---
VLLM_INSTALL_AUDIO_DEPS=0
#VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 for 80 GB GPUs; reduce to 64-128 for ≤40 GB
#VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
#VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
