# =============================================================================
# Nemotron-3-Super-120B-A12B-NVFP4 — DGX Spark (GB10 / SM12.1)
# Usage: docker compose --env-file .env.super up -d
#
# Pre-flight:
#   mkdir -p reasoning_parsers
#   wget https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4/raw/main/super_v3_reasoning_parser.py \
#        -P ./reasoning_parsers/
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4
VLLM_SERVED_MODEL_NAME=nemotron-3-super
CONTAINER_NAME=vllm-super

# --- SM12.1 kernel routing ---
# Super uses Marlin exclusively — FlashInfer FP4 path is disabled
VLLM_NVFP4_GEMM_BACKEND=marlin
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_FLASHINFER_MOE_BACKEND=latency
# Required for Super's LatentMoE all-reduce on nightly
VLLM_FLASHINFER_ALLREDUCE_BACKEND=trtllm

# --- Context / memory ---
# Set to 1 to unlock up to --max-model-len 1048576
# Keep at 262144 unless you specifically need >256k context
VLLM_ALLOW_LONG_MAX_MODEL_LEN=0
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=4
VLLM_GPU_MEMORY_UTILIZATION=0.85

# --- Quantization ---
# Super requires explicit --quantization fp4 (checkpoint uses MIXED_PRECISION
# quant_algo which requires nightly to load; fp4 overrides the whitelist check)
VLLM_QUANTIZATION_FLAG=--quantization fp4

# --- MoE / Mamba ---
VLLM_MOE_BACKEND=marlin
MAMBA_SSM_CACHE_DTYPE=float32

# --- Scheduling ---
# async-scheduling improves throughput on Super's LatentMoE architecture
VLLM_ASYNC_SCHEDULING_FLAG=--async-scheduling

# --- CUDA graph ---
# Limits capture size to reduce memory pressure during the ~8-10min startup
VLLM_CUDAGRAPH_FLAG=--max-cudagraph-capture-size 128

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8

# --- Parsers ---
VLLM_REASONING_PARSER_PLUGIN=/app/reasoning_parsers/super_v3_reasoning_parser.py
VLLM_REASONING_PARSER=super_v3
VLLM_TOOL_CALL_PARSER=qwen3_coder

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
VLLM_PORT=8000
