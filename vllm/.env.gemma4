# =============================================================================
# RedHatAI/gemma-4-26B-A4B-it-FP8-Dynamic — text / reasoning / tool-calling
# Usage: docker compose --env-file .env.gemma4 up -d
#
# Note: This model is FP8-quantized with BF16 activations and works with vllm main.
# Model card: https://huggingface.co/nvidia/Gemma-4-26B-A4B-NVFP4
# =============================================================================

# --- Model ---
VLLM_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
VLLM_SERVED_MODEL_NAME=vllm
CONTAINER_NAME=vllm

# --- Reasoning / tool calling ---
VLLM_REASONING_PARSER=gemma4
VLLM_TOOL_CALL_PARSER=gemma4

# --- Model backend ---
# No MoE-specific backend is required for this Gemma FP8 model.
VLLM_MOE_BACKEND=flashinfer_cutlass
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_NVFP4_GEMM_BACKEND=marlin

# --- Speculative decoding (MTP) ---
#VLLM_SPECULATIVE_CONFIG_FLAG=--speculative-config '{"method": "mtp", "num_speculative_tokens": 3}'

# --- Context / memory ---
VLLM_MAX_MODEL_LEN=262144
VLLM_MAX_NUM_SEQS=16
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_GPU_MEMORY_UTILIZATION=0.75

# --- KV cache ---
VLLM_KV_CACHE_DTYPE=fp8_e4m3
# BF16 is correct for this model's activation type; float16 is narrower dynamic range.
VLLM_DTYPE=auto

# --- Multimodal flags (image + video; no audio) ---
VLLM_INSTALL_AUDIO_DEPS=0
#VLLM_VIDEO_PRUNING_FLAG=--video-pruning-rate 0.5
# num_frames=256 for 80 GB GPUs; reduce to 64-128 for ≤40 GB
#VLLM_MEDIA_IO_KWARGS_FLAG=--media-io-kwargs '{"video": {"fps": 2, "num_frames": 256}}'
#VLLM_ALLOWED_LOCAL_MEDIA_FLAG=--allowed-local-media-path /

# --- HF / infra ---
HF_CACHE_DIR=~/.cache/huggingface
HF_TOKEN=
