# Path on the host where Prometheus stores its time-series data
PROMETHEUS_DATA_PATH=/opt/monitoring/prometheus

# Path on the host where Grafana stores its database and plugins
GRAFANA_DATA_PATH=/opt/monitoring/grafana

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Traefik domain for Grafana
GRAFANA_TRAEFIK_DOMAIN=grafana.example.com
