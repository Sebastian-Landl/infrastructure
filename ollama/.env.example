# Maximum context length for the model
OLLAMA_CONTEXT_LENGTH=262144

# Enable Flash Attention optimization
OLLAMA_FLASH_ATTENTION=true

# KV Cache quantization type (e.g., f16, q8_0, q4_0)
OLLAMA_KV_CACHE_TYPE=q8_0

# Path to store Ollama models and data
OLLAMA_MODEL_PATH=./ollama_data

# GPU driver to use (nvidia, amd, etc.)
GPU_DRIVER=nvidia

# The maximum number of models that can be loaded concurrently provided they fit in available memory
OLLAMA_MAX_LOADED_MODELS=3
# The maximum number of parallel requests each model will process at the same time, default 1. Required RAM will scale by OLLAMA_NUM_PARALLEL * OLLAMA_CONTEXT_LENGTH.
OLLAMA_NUM_PARALLEL=1
