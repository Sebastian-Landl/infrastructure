############################
# Compose Profile Selection
############################
# Single-file toggle:
# - cpu: starts OpenWebUI without GPU reservation
# - gpu: starts OpenWebUI with NVIDIA GPU reservation
COMPOSE_PROFILES=gpu
GPU_DRIVER=nvidia
OPENWEBUI_VERSION=v0.8.12

############################
# Routing / Public Access
############################
OPENWEBUI_DATA_PATH=./openwebui_data
OPENWEBUI_TRAEFIK_DOMAIN=openwebui.example.com
WEBUI_URL=https://openwebui.example.com

############################
# Admin Bootstrap (first run)
############################
# On a fresh data volume, if both values below are set, OpenWebUI creates
# the admin user automatically and disables signup.
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=change_me_to_a_strong_unique_password
WEBUI_ADMIN_NAME=Admin

############################
# Security / Privacy Defaults
############################
# IMPORTANT: set a long random value and keep it stable across restarts.
WEBUI_SECRET_KEY=replace_with_a_long_random_secret
ENABLE_SIGNUP=false
# Controls if db (with possible edits in the UI) or env vars are the preferred data source.
ENABLE_PERSISTENT_CONFIG=true
ENABLE_FORWARD_USER_INFO_HEADERS=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_VERSION_UPDATE_CHECK=false
# (Dis)allows whether local addresses can be fetched from. Keep it off for more security.
ENABLE_RAG_LOCAL_WEB_FETCH=false
WEBUI_SESSION_COOKIE_SECURE=true
WEBUI_AUTH_COOKIE_SECURE=true
WEBUI_SESSION_COOKIE_SAME_SITE=lax
WEBUI_AUTH_COOKIE_SAME_SITE=lax
DEFAULT_USER_ROLE=pending

############################
# LLM backend
############################
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=sk-replace_with_your_litellm_master_key_or_proxy_key

# Disable direct Ollama path by default (can be enabled later from env/UI).
ENABLE_OLLAMA_API=false

# Optional: default model IDs available through LiteLLM, comma-separated.
DEFAULT_MODELS=

RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL=http://litellm:4000/v1
RAG_OPENAI_API_KEY=sk-replace_with_your_litellm_master_key_or_proxy_key
RAG_EMBEDDING_MODEL=qwen3-embedding-large
RAG_EMBEDDING_BATCH_SIZE=64

# PDF Loader Modes:
# page - Creates one document per page (default).
# single - Combines all pages into one document for better chunking across page boundaries.
PDF_LOADER_MODE=single
RAG_TOP_K=20
RAG_TOP_K_RERANKER=10
ENABLE_RAG_HYBRID_SEARCH=True
ENABLE_RAG_HYBRID_SEARCH_ENRICHED_TEXTS=True


############################
# Web Search (optional)
############################
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=duckduckgo
WEB_SEARCH_RESULT_COUNT=5
WEB_SEARCH_CONCURRENT_REQUESTS=1
WEB_LOADER_CONCURRENT_REQUESTS=5
