# Example environment variables for SeaweedFS docker-compose
# Copy to .env and replace placeholders with real values before deploying.

# Data path for SeaweedFS (host path or named volume)
SEAWEEDFS_DATA=./seaweedfs_data

# Path to the s3.json config file (relative to compose file or absolute)
SEAWEEDFS_S3_CONFIG_PATH=./s3.json

# Public-facing domains used by Traefik labels (replace with your domains)
SEAWEEDFS_S3_DOMAIN=seaweed-s3.example.com
SEAWEEDFS_ADMIN_DOMAIN=seaweed-admin.example.com

